rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validRoomCode(roomCode) {
      return roomCode is string && roomCode.matches('^[0-9]{4}$');
    }

    function roomPath(roomCode) {
      return /databases/$(database)/documents/secret_rooms/$(roomCode);
    }

    function roomExists(roomCode) {
      return validRoomCode(roomCode) && exists(roomPath(roomCode));
    }

    function roomData(roomCode) {
      return get(roomPath(roomCode)).data;
    }

    function isRoomParticipant(roomCode) {
      return signedIn()
        && roomExists(roomCode)
        && request.auth.uid in roomData(roomCode).participants;
    }

    match /config/{documentId} {
      allow read: if true;
      allow write: if false;
    }

    match /secret_rooms/{roomCode} {
      allow read: if signedIn() && validRoomCode(roomCode);

      allow create: if signedIn()
        && validRoomCode(roomCode)
        && request.resource.data.keys().hasOnly([
          'participants',
          'creator',
          'createdAt',
          'updatedAt',
          'schemaVersion',
          'status'
        ])
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 1
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.creator == request.auth.uid
        && (!('createdAt' in request.resource.data) || request.resource.data.createdAt == request.time)
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt == request.time)
        && (!('schemaVersion' in request.resource.data) || request.resource.data.schemaVersion == 1)
        && (!('status' in request.resource.data) || request.resource.data.status == 'active');

      allow update: if signedIn()
        && validRoomCode(roomCode)
        && resource.data.participants is list
        && request.resource.data.participants is list
        && request.resource.data.creator == resource.data.creator
        && request.resource.data.participants.size() <= 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.hasAll(resource.data.participants)
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt == request.time)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'participants',
          'updatedAt'
        ]);

      allow delete: if signedIn() && resource.data.creator == request.auth.uid;
    }

    match /secret_messages/{messageId} {
      allow read: if isRoomParticipant(resource.data.roomCode);

      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'text',
          'sender',
          'senderId',
          'roomCode',
          'createdAt',
          'moderation'
        ])
        && validRoomCode(request.resource.data.roomCode)
        && isRoomParticipant(request.resource.data.roomCode)
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.sender is string
        && request.resource.data.sender.size() <= 80
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 300
        && request.resource.data.createdAt == request.time;

      allow update: if false;
      allow delete: if isRoomParticipant(resource.data.roomCode);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
